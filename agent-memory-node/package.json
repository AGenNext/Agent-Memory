{
  "name": "@agentnxxt/agent-memory",
  "version": "0.1.0",
  "description": "Embedded AI agent memory layer — Ebbinghaus decay, episodic replay, conflict resolution",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AGenNext/Agent-Memory.git"
  },
  "homepage": "https://github.com/AGenNext/Agent-Memory",
  "keywords": [
    "ai", "agent", "memory", "langchain", "llm", "surrealdb",
    "crewai", "autogen", "llamaindex", "mcp"
  ],
  "napi": {
    "name": "agent-memory",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "aarch64-apple-darwin",
        "x86_64-apple-darwin"
      ]
    }
  },
  "engines": {
    "node": ">= 18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build":       "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3"
  },
  "optionalDependencies": {
    "@agentnxxt/agent-memory-linux-x64-gnu":   "0.1.0",
    "@agentnxxt/agent-memory-linux-arm64-gnu":  "0.1.0",
    "@agentnxxt/agent-memory-darwin-arm64":     "0.1.0",
    "@agentnxxt/agent-memory-darwin-x64":       "0.1.0",
    "@agentnxxt/agent-memory-win32-x64-msvc":   "0.1.0"
  }
}
